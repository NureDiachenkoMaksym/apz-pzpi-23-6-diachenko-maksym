digraph G {
  graph [rankdir=LR, bgcolor="white", pad="0.25", nodesep="0.45", ranksep="0.75"];
  node [fontname="DejaVu Sans", fontsize=11, shape=component, style="filled", fillcolor="#F6FAFF", color="#1F4E79"];
  edge [fontname="DejaVu Sans", fontsize=10, color="#333333"];
  subgraph cluster_mobile { label="Android-застосунок"; fontname="DejaVu Sans"; fontsize=13; color="#90A4AE";
    ui [label="UI Layer\nJetpack Compose"];
    vm [label="ViewModel\nстан екранів"];
    repo [label="Repository\nбізнес-логіка"];
    api [label="ApiClient\nRetrofit/Ktor"];
    db [label="Local Storage\nRoom/DataStore"];
    sync [label="Sync Worker\nWorkManager"];
  }
  backend [label="Backend API\nNatural Resources System", fillcolor="#E8F5E9", color="#2E7D32"];
  centraldb [label="Central DB\nPostgreSQL", fillcolor="#E8F5E9", color="#2E7D32"];
  web [label="Web client\nAdmin/Analyst UI", fillcolor="#FFF8E1", color="#8A6D00"];
  iot [label="IoT sensors\noptional data source", fillcolor="#FFF8E1", color="#8A6D00"];
  ui -> vm; vm -> repo; repo -> api; repo -> db; sync -> repo; api -> backend [label="REST HTTPS"]; backend -> centraldb; web -> backend; iot -> backend;
